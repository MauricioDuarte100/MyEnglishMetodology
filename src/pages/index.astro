---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="English Vocabulary Learning App - Practice and master essential English vocabulary">
  <title>VOCAB | English Learning</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
  <div class="app">
    <!-- Header -->
    <header class="header">
      <div class="logo">VOCAB</div>
      
      <div class="controls-container">
        <div class="language-selector">
          <select id="languageSelect" class="lang-select">
            <option value="en">🇺🇸 English</option>
            <option value="ru">🇷🇺 Русский</option>
          </select>
        </div>

        <div class="set-container" id="setContainer">
          <select id="setSelect" class="set-select">
            <option value="1">Set 1 (1-50)</option>
          </select>
        </div>
      </div>

      <div class="progress-indicator" id="progressIndicator">
        <span class="progress-text">0 / 0</span>
        <div class="progress-bar">
          <div class="progress-fill" id="progressFill"></div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="main">
      <!-- Category Selection -->
      <nav class="category-nav" id="categoryNav">
        <button class="category-btn active" data-category="core">
          <span class="category-icon">1K</span>
          <span class="category-label">Core 1000</span>
        </button>
        <button class="category-btn" data-category="advanced">
          <span class="category-icon">2K</span>
          <span class="category-label">Advanced</span>
        </button>
        <button class="category-btn" data-category="technical">
          <span class="category-icon">T</span>
          <span class="category-label">Technical</span>
        </button>
      </nav>

      <!-- Mode Selection -->
      <div class="mode-nav" id="modeNav">
        <button class="mode-btn active" data-mode="flashcard">Tarjetas</button>
        <button class="mode-btn" data-mode="quiz">Quiz</button>
        <button class="mode-btn" data-mode="typing">Escribir</button>
        <button class="mode-btn" data-mode="fillblanks">Completar</button>
        <button class="mode-btn" data-mode="matching">Parejas</button>
        <button class="mode-btn" data-mode="reading">Lectura</button>
      </div>

      <!-- Flashcard Mode -->
      <section class="flashcard-container" id="flashcardMode">
        
        <div class="flashcard-header">
           <div class="flashcard-counter">
             Tarjeta <strong id="flashcardCurrentCount">1</strong> de <strong id="flashcardTotalCount">50</strong>
           </div>
           <div class="flashcard-timer">
              <select id="timerSelect" class="timer-select">
                 <option value="0">Sin tiempo límite</option>
                 <option value="5">5 Minutos</option>
                 <option value="10">10 Minutos</option>
                 <option value="20">20 Minutos</option>
                 <option value="40">40 Minutos</option>
              </select>
              <span id="timerDisplay" class="timer-display">--:--</span>
              <button id="startTimerBtn" class="timer-btn">Iniciar</button>
           </div>
        </div>

        <div class="flashcard" id="flashcard">
          <div class="flashcard-front">
            <!-- 1. Top: Russian Word (Big, Accent) -->
            <div class="ru-word-main hidden" id="ruWordMain"></div>
            
            <!-- 2. Letter Breakdown (Cyrillic -> Latin) -->
            <div class="ru-letter-breakdown hidden" id="ruLetterBreakdown"></div>

            <!-- 3. Spanish Meaning -->
            <div class="ru-meaning hidden" id="ruMeaning"></div>
            
            <!-- 4. Phonetic -->
            <div class="ru-phonetic hidden" id="ruPhonetic"></div>
            
            <!-- 5. Audio Button -->
            <button class="audio-btn-icon" id="flashcardAudioBtn" title="Escuchar">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 5L6 9H2v6h4l5 4V5zM19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07" />
              </svg>
            </button>
            
            <!-- English Mode Fallback (Hidden for Russian) -->
            <span class="word hidden" id="currentWord">eloquent</span>
            <span class="phonetic hidden" id="phonetic">/élokuent/</span>
            
            <span class="hint">Clic para ver ejemplo</span>
          </div>
          <div class="flashcard-back">
            <span class="definition" id="definition">fluent or persuasive in speaking or writing</span>
            <span class="example" id="example">"She gave an eloquent speech about climate change."</span>
            
            <!-- Dual Translation Container -->
            <div class="translations-container">
               <span class="translation-primary" id="translationPrimary">elocuente</span>
               <span class="translation-secondary" id="translationSecondary"></span>
            </div>

            <div class="association-container">
              <label for="associationInput">🧠 Mi Hook/Asociación:</label>
              <textarea id="associationInput" placeholder="Visualiza una imagen o historia..."></textarea>
            </div>
          </div>
        </div>
        <div class="flashcard-actions">
          <button class="action-btn prev" id="prevBtn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 18l-6-6 6-6" />
            </svg>
          </button>
          <button class="action-btn learning" id="learningBtn">Repasar</button>
          <button class="action-btn know" id="knowBtn">Aprendido</button>
          <button class="action-btn next" id="nextBtn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 18l6-6-6-6" />
            </svg>
          </button>
        </div>
      </section>

      <!-- Quiz Mode -->
      <section class="quiz-container hidden" id="quizMode">
        <div class="quiz-question">
          <span class="quiz-prompt">¿Qué significa:</span>
          <span class="quiz-word" id="quizWord">eloquent</span>
          <span class="quiz-phonetic" id="quizPhonetic">/élokuent/</span>
          <button class="audio-btn-icon small" id="quizAudioBtn" title="Play pronuncation">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M11 5L6 9H2v6h4l5 4V5zM19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07" />
            </svg>
          </button>
        </div>
        <div class="quiz-options" id="quizOptions">
          <button class="quiz-option" data-index="0">Option 1</button>
          <button class="quiz-option" data-index="1">Option 2</button>
          <button class="quiz-option" data-index="2">Option 3</button>
          <button class="quiz-option" data-index="3">Option 4</button>
        </div>
        <div class="quiz-feedback hidden" id="quizFeedback">
          <span class="feedback-text"></span>
          <button class="next-question-btn" id="nextQuestionBtn">Siguiente Pregunta</button>
        </div>
        <div class="quiz-score" id="quizScore">
          <span>Score: <strong id="scoreValue">0</strong> / <strong id="totalQuestions">0</strong></span>
        </div>
      </section>

      <!-- Matching Mode -->
      <section class="matching-container hidden" id="matchingMode">
        <div class="matching-header">
           <div class="matching-stats">
              <span class="matching-stat">Pairs: <strong id="matchingScore">0</strong> / 4</span>
           </div>
        </div>
        <div class="matching-grid" id="matchingGrid">
           <!-- Cards injected via JS -->
        </div>
        <div class="matching-feedback hidden" id="matchingFeedback">
            <span class="feedback-text">¡Nivel Completado!</span>
            <button class="next-level-btn" id="nextLevelBtn">Siguiente Nivel</button>
        </div>
      </section>

      <!-- Typing Mode -->
      <section class="typing-container hidden" id="typingMode">
        <div class="typing-prompt">
          <span class="typing-definition" id="typingDefinition">fluent or persuasive in speaking or writing</span>
          <span class="typing-example" id="typingExample">"She gave an _______ speech about climate change."</span>
          <div class="typing-format-hint" id="typingFormatHint">_ _ _ _ _ _ _ _</div>
        </div>
        <div class="typing-input-wrapper">
          <input type="text" class="typing-input" id="typingInput" placeholder="Escribe la palabra..." autocomplete="off">
          <button class="typing-submit" id="typingSubmit">Comprobar</button>
        </div>
        <div class="typing-actions" style="margin-top: 10px;">
           <button class="action-btn" id="typingHintBtn">💡 Dar una Pista</button>
        </div>
        <div class="typing-feedback hidden" id="typingFeedback">
          <span class="feedback-text"></span>
          <button class="next-word-btn" id="nextWordBtn">Siguiente Palabra</button>
        </div>
      </section>

      <!-- Fill in the Blanks Mode -->
      <section class="fillblanks-container hidden" id="fillblanksMode">
         <div class="fillblanks-header">
           <h3 style="margin-bottom: 0.5rem;">Cuales faltan?</h3>
           <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1rem;">Selecciona la palabra correcta para completar cada oración.</p>
         </div>
         <div class="fillblanks-content" id="fillblanksContent">
            <!-- Selections injected here -->
         </div>
         <div class="fillblanks-actions" style="margin-top: 2rem; display: flex; gap: 1rem; justify-content: center;">
             <button class="action-btn" id="generateBlanksBtn">🔃 Mezclar Otro</button>
             <button class="action-btn know" id="fillblanksSubmit">Revisar Respuestas</button>
         </div>
         <div class="fillblanks-feedback hidden" id="fillblanksFeedback" style="margin-top: 1rem; text-align: center;">
             <span class="feedback-text"></span>
         </div>
      </section>

      <!-- Reading Mode -->
      <section class="reading-container hidden" id="readingSection">
        <div class="reading-header">
          <h2 class="reading-title">Reading Practice</h2>
          <p class="reading-subtitle">British English texts with idioms</p>
        </div>

        <div class="custom-reading-form">
          <div class="form-group">
            <label for="readingTopic">Tema (ej. Trabajo, Viajes):</label>
            <input type="text" id="readingTopic" placeholder="Escribe un tema..." class="reading-input" value="Trabajo">
          </div>
          <div class="form-group">
            <label for="readingLevel">Nivel de dificultad:</label>
            <select id="readingLevel" class="reading-select">
              <option value="beginner">Principiante (A1-A2)</option>
              <option value="intermediate" selected>Intermedio (B1-B2)</option>
              <option value="advanced">Avanzado (C1-C2)</option>
            </select>
          </div>
        </div>

        <button class="generate-btn" id="generateTextBtn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83" />
          </svg>
          Generar Nuevo Texto
        </button>

        <div class="reading-loading hidden" id="readingLoading">
          <div class="spinner"></div>
          <span>Generando texto con IA...</span>
        </div>

        <div class="reading-error hidden" id="readingError"></div>

        <div class="reading-text-container hidden" id="readingTextContainer">
          <div class="reading-text" id="readingTextContent"></div>
        </div>

        <!-- Word Tooltip -->
        <div class="word-tooltip hidden" id="wordTooltip"></div>
      </section>
    </main>

    <!-- Filter Modal -->
    <div class="modal hidden" id="filterModal">
      <div class="modal-content">
        <h3>Filtrar Vocabulario</h3>
        <div class="filter-options">
          <label class="filter-option">
            <input type="checkbox" id="filterAll" checked> Todas
          </label>
          <label class="filter-option">
            <input type="checkbox" id="filterLearning"> Estudiando
          </label>
          <label class="filter-option">
            <input type="checkbox" id="filterMastered"> Aprendidas
          </label>
        </div>
        <div class="subcategory-filter hidden" id="subcategoryFilter">
          <h4>Technical Categories</h4>
          <label class="filter-option">
            <input type="checkbox" data-sub="business" checked> Business & Marketing
          </label>
          <label class="filter-option">
            <input type="checkbox" data-sub="it" checked> IT & Cybersecurity
          </label>
          <label class="filter-option">
            <input type="checkbox" data-sub="data" checked> Data Analytics
          </label>
          <label class="filter-option">
            <input type="checkbox" data-sub="finance" checked> Finance
          </label>
        </div>
        <button class="modal-close" id="closeFilterModal">Aplicar</button>
      </div>
    </div>
  </div>

  <script src="../scripts/main.js"></script>
</body>
</html>
